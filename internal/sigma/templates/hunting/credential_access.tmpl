title: 'Dragnet [Hunt]: {{.DragnetID}} — {{.Behaviour.ID}} Credential ENV Variable Harvesting'
id: {{.ID}}
status: {{.Status}}
description: |
  Detects processes spawned from package manager scripts reading sensitive environment
  variables (API keys, tokens, cloud credentials) or cloud metadata endpoints.
  Behaviour: {{.Behaviour.ID}} — {{.Behaviour.Description}}
  Incident: {{.DragnetID}}
  {{.Description}}
references:
{{- range .References}}
  - {{.}}
{{- end}}
author: dragnet-bot
date: {{.Date}}
tags:
  - attack.t1552.001
  - attack.t1552.004
  - attack.t1059.004
{{- range .Tags}}
  - {{.}}
{{- end}}
logsource:
  category: process_creation
  product: any
detection:
  selection_env_read:
    ParentImage|contains:
      - 'npm'
      - 'node'
      - 'pip'
      - 'cargo'
    CommandLine|contains:
      - 'AWS_SECRET'
      - 'AWS_ACCESS'
      - 'GITHUB_TOKEN'
      - 'NPM_TOKEN'
      - 'CI_JOB_TOKEN'
      - 'CIRCLE_TOKEN'
      - 'BUILDKITE'
      - 'ARTIFACTORY'
  selection_metadata:
    ParentImage|contains:
      - 'npm'
      - 'node'
      - 'pip'
      - 'cargo'
    CommandLine|contains:
      - '169.254.169.254'
      - 'metadata.google.internal'
      - 'metadata.azure.com'
  condition: selection_env_read or selection_metadata
falsepositives:
  - Legitimate CI/CD scripts that read their own credentials
level: {{.Level}}
