title: 'Dragnet [Ransomware]: {{.DragnetID}} — Event Log Clearing ({{.RansomwareGroup}})'
id: {{.ID}}
status: {{.Status}}
description: |
  Detects event log clearing associated with {{.RansomwareGroup}} ransomware.
  Incident: {{.DragnetID}}
  {{.Description}}
references:
{{- range .References}}
  - {{.}}
{{- end}}
author: dragnet-bot
date: {{.Date}}
tags:
  - attack.t1070.001
{{- range .Tags}}
  - {{.}}
{{- end}}
logsource:
  category: process_creation
  product: windows
detection:
  selection_wevtutil:
    Image|endswith: '\wevtutil.exe'
    CommandLine|contains:
      - ' cl '
      - ' clear-log '
  selection_powershell:
    Image|endswith:
      - '\powershell.exe'
      - '\pwsh.exe'
    CommandLine|contains: 'Clear-EventLog'
  condition: 1 of selection_*
falsepositives:
  - Legitimate log maintenance scripts
level: {{.Level}}
