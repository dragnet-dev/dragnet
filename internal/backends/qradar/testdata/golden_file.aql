-- Dragnet [IOC]: npm-2026-002 — Malicious File Hash
-- Status: stable | Level: high | ID: b2c3d4e5-f6a7-8901-bcde-f01234567891
SELECT DATEFORMAT(starttime,'YYYY-MM-dd HH:mm:ss') AS "Start Time", sourceip, filename, "Application"
FROM events
WHERE (sha256hash = 'ab4fcadaec3a4b0f0f5e96a8c8c23e2f1d0a9b8c7d6e5f4a3b2c1d0e9f8a7b6')
LAST 24 HOURS
