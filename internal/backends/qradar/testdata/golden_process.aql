-- Dragnet [Hunt]: npm-2026-003 — Suspicious Process Access
-- Status: experimental | Level: medium | ID: c3d4e5f6-a7b8-9012-cdef-012345678902
SELECT DATEFORMAT(starttime,'YYYY-MM-dd HH:mm:ss') AS "Start Time", sourceip, "Application", "Command"
FROM events
WHERE ("Application" ILIKE '%node%')
  AND ("Command" ILIKE '%/proc/%')
LAST 24 HOURS
